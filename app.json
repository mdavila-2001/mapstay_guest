{
  "expo": {
    "name": "MapStay Huésped",
    "slug": "mapstay_guest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mapstay.mapstayguest",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MapStay necesita acceso a tu ubicación para mostrar alojamientos cercanos."
      }
    },
    "android": {
      "package": "com.mapstay.mapstayguest",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
